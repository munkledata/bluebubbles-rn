{
  "name": "gator-rn",
  "version": "0.1.26",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage:ui": "jest --coverage --collectCoverageFrom='src/ui/**/*.{ts,tsx}' --collectCoverageFrom='!src/ui/**/index.ts' --coverageReporters=text --coverageReporters=json-summary",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src app",
    "release:android": "npm version patch --no-git-tag-version && eas build -p android --profile production --auto-submit",
    "release:android:local": "npm version patch --no-git-tag-version && eas build -p android --profile production --local --output ./gator-release.aab && eas submit -p android --path ./gator-release.aab",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@op-engineering/op-sqlite": "^17.0.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-firebase/app": "^25.0.0",
    "@react-native-firebase/messaging": "^25.0.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.101.0",
    "drizzle-orm": "^0.45.2",
    "expo": "~57.0.7",
    "expo-asset": "~57.0.6",
    "expo-audio": "~57.0.2",
    "expo-background-task": "~57.0.5",
    "expo-build-properties": "~57.0.6",
    "expo-camera": "~57.0.3",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.5",
    "expo-contacts": "~57.0.2",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-document-picker": "~57.0.1",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-picker": "~57.0.5",
    "expo-intent-launcher": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-local-authentication": "~57.0.1",
    "expo-media-library": "~57.0.3",
    "expo-network": "~57.0.1",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-share-intent": "^8.0.1",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-task-manager": "~57.0.5",
    "expo-video": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "jail-monkey": "^3.0.0",
    "ky": "^1.7.2",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-image-colors": "^2.6.0",
    "react-native-libsodium": "^1.7.0",
    "react-native-notify-kit": "^10.4.8",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-ssl-public-key-pinning": "^1.2.6",
    "react-native-webview": "13.16.1",
    "socket.io-client": "^4.8.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~57.0.0",
    "better-sqlite3": "^12.11.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "libsodium-wrappers": "^0.7.15",
    "libsodium-wrappers-sumo": "^0.7.16",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "react-dom": "19.2.3",
    "react-native-image-colors": {
      "file-type": "^21.3.1"
    },
    "xcode": {
      "uuid": "^11.1.1"
    }
  },
  "op-sqlite": {
    "sqlcipher": true,
    "fts5": true
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-notify-kit",
          "react-native-libsodium"
        ]
      }
    }
  }
}
