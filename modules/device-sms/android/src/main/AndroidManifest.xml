<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- No permissions declared here; SEND_SMS / READ_SMS / RECEIVE_SMS are added to
       the app manifest via app.config.ts android.permissions and requested at runtime
       JS-side via PermissionsAndroid. The AGP namespace is set in build.gradle. -->

  <!-- Manifest-registered receiver for the KILLED-APP incoming-SMS path. Declared here in
       the library manifest and merged into the app manifest so it is delivered even when
       the process is dead. SMS_RECEIVED is exempt from Android 8 implicit-broadcast limits
       and is delivered to a non-default SMS app's manifest receivers; the BROADCAST_SMS
       permission restricts the sender to the system. The class name is fully-qualified (the
       app package differs from this library's namespace, so a relative ".Name" would resolve
       against the wrong package during the manifest merge). -->
  <application>
    <receiver
      android:name="com.bluegreengatorapps.devicesms.DeviceSmsReceiver"
      android:exported="true"
      android:permission="android.permission.BROADCAST_SMS">
      <intent-filter>
        <action android:name="android.provider.Telephony.SMS_RECEIVED" />
      </intent-filter>
    </receiver>

    <!-- Killed-app INCOMING-MMS path. WAP_PUSH_RECEIVED (mime application/vnd.wap.mms-message)
         is the system signal that an MMS is being pushed; it is gated by BROADCAST_WAP_PUSH
         (a DIFFERENT sender permission than SMS_RECEIVED's BROADCAST_SMS), so it must be a
         SEPARATE receiver entry (android:permission is per-receiver). The receiver posts a
         generic notification only — it does NOT parse the PDU (the body downloads async). -->
    <receiver
      android:name="com.bluegreengatorapps.devicesms.DeviceSmsMmsReceiver"
      android:exported="true"
      android:permission="android.permission.BROADCAST_WAP_PUSH">
      <intent-filter>
        <action android:name="android.provider.Telephony.WAP_PUSH_RECEIVED" />
        <data android:mimeType="application/vnd.wap.mms-message" />
      </intent-filter>
    </receiver>
  </application>
</manifest>
